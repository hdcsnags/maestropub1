# Session 74 environment variables
# Copy this file to .env and update values for your local environment.

# Application
NODE_ENV=development
PORT=3000
APP_NAME=Session74
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/session74

# Authentication
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me-to-a-different-long-random-string

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Optional integrations
REDIS_URL=redis://localhost:6379

# Frontend public variables
PUBLIC_APP_URL=http://localhost:3000
